# Base de datos administrada para el backend desplegado.
DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# URL pública del frontend desplegado para CORS.
# Déjala sin slash final para evitar mismatches exactos de origin.
FRONTEND_URL=https://tu-frontend.vercel.app

# Secreto de sesión del backend.
SESSION_SECRET=tZfstnYORyfi2JsJJqTG1e1s9aQKesWZUxRABAY8PBP

# Ajustes recomendados si frontend y backend viven en dominios distintos.
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_SECURE=true

# Cloudinary — imágenes de productos terminados
# Obtén estos valores en https://cloudinary.com > Dashboard.
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_PRODUCT_FOLDER=tacos-el-pepe/productos
