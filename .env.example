# PostgreSQL - Docker Compose
POSTGRES_USER=proy2
POSTGRES_PASSWORD=secret
POSTGRES_DB=tacospepe
POSTGRES_PORT=5433

# Backend - Conexión a la base de datos
# Desarrollo local / Docker:
# deja DATABASE_URL vacío y usa DB_HOST/DB_PORT contra la base local.
# Producción / Neon:
# configura DATABASE_URL en el hosting del backend y deja DB_HOST/DB_PORT sin uso.
DATABASE_URL=
DB_HOST=localhost
# Para desarrollo local fuera de Docker, usa el mismo valor que POSTGRES_PORT.
DB_PORT=5433

# Backend - Servidor
PORT=3000
SESSION_SECRET=G9qW3Lx8Ns2Vb7Km4Pd1Yt6Hr0Cf5Ju9Re3Xa8Mz2Uk7Wp4Dn1Tv6Bh0Qs5Lc8Ef
FRONTEND_URL=http://localhost:5173

# Frontend
FRONTEND_PORT=5173

# Cloudinary — imágenes de productos terminados
# Crea una cuenta gratis en https://cloudinary.com y copia los valores del Dashboard.
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
# Carpeta en Cloudinary donde se guardarán las fotos (opcional, hay valor por defecto).
CLOUDINARY_PRODUCT_FOLDER=tacos-el-pepe/productos
